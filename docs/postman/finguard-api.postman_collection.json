    {
      "name": "Score Transaction - High Risk BLOCK",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transactionId\": \"txn-demo-block-001\",\n  \"amount\": 150000,\n  \"currency\": \"INR\",\n  \"country\": \"BR\",\n  \"deviceId\": \"unknown-device-909\",\n  \"customerId\": \"cust-demo-003\",\n  \"failedLogins\": 7,\n  \"velocity\": 14,\n  \"networkStatus\": \"DEGRADED\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/score",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "score"
          ]
        },
        "description": "Scores a high-risk transaction. Expected decision: BLOCK."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Transaction is blocked\", function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.decision).to.eql(\"BLOCK\");",
              "  pm.expect(body.reasons.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ]
    },
