{
  "info": {
    "_postman_id": "cc6a2274-1f59-43c8-91db-finguard-lite",
    "name": "FinGuard Lite Fraud API",
    "description": "Live API requests for demonstrating the FinGuard Lite fraud scoring backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://3.110.140.20",
      "type": "string"
    },
    {
      "key": "prometheus_url",
      "value": "http://3.110.140.20:30090",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Checks if the fraud API is healthy and returns active scoring thresholds."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Health endpoint is OK\", function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql(\"ok\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Score Transaction - Low Risk ALLOW",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"transactionId\": \"txn-demo-allow-001\",\n  \"amount\": 1200,\n  \"currency\": \"INR\",\n  \"country\": \"IN\",\n  \"deviceId\": \"device-known-101\",\n  \"customerId\": \"cust-demo-001\",\n  \"failedLogins\": 0,\n  \"velocity\": 1,\n  \"networkStatus\": \"OK\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/score",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "score"
          ]
        },
        "description": "Scores a normal transaction. Expected decision: ALLOW."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Transaction scored\", function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property(\"riskScore\");",
              "  pm.expect(body).to.have.property(\"decision\");",
              "  pm.expect(body.decision).to.eql(\"ALLOW\");",
              "});"
            ]
          }
        }
      ]
    },
