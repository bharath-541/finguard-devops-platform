          ]
        },
        "description": "Simulates a risky transaction during payment network downtime."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Network failure transaction scored\", function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.reasons).to.include(\"payment_network_timeout\");",
              "});"
            ]
          }
        }
      ]
